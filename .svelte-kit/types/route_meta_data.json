{
	"/(public)": [
		"src/routes/(public)/+page.server.ts",
		"src/routes/(public)/+layout.server.ts",
		"src/routes/+layout.server.ts",
		"src/routes/(public)/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/": [
		"src/routes/+layout.server.ts"
	],
	"/(public)/auth/login": [
		"src/routes/(public)/auth/login/+page.server.ts",
		"src/routes/(public)/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/(public)/auth/register": [
		"src/routes/(public)/auth/register/+page.server.ts",
		"src/routes/(public)/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/(public)/auth/verify": [
		"src/routes/(public)/auth/verify/+page.server.ts",
		"src/routes/(public)/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/turbo/path-configuration": [
		"src/routes/turbo/path-configuration/+server.ts"
	],
	"/(app)/[tenant=username]": [
		"src/routes/(app)/[tenant=username]/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/(app)/[tenant=username]/settings": [
		"src/routes/(app)/[tenant=username]/settings/+page.server.ts",
		"src/routes/(app)/[tenant=username]/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/(app)/[tenant=username]/todos": [
		"src/routes/(app)/[tenant=username]/todos/+page.server.ts",
		"src/routes/(app)/[tenant=username]/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/(app)/[tenant=username]/todos/new": [
		"src/routes/(app)/[tenant=username]/todos/new/+page.server.ts",
		"src/routes/(app)/[tenant=username]/+layout.server.ts",
		"src/routes/+layout.server.ts"
	],
	"/(app)/[tenant=username]/todos/[id]": [
		"src/routes/(app)/[tenant=username]/todos/[id]/+page.server.ts",
		"src/routes/(app)/[tenant=username]/+layout.server.ts",
		"src/routes/+layout.server.ts"
	]
}